---
const SITE_NAME = "やめる前相談室";
const PAGE_TITLE = `退職前コラム｜${SITE_NAME}`;
const PAGE_DESC = "退職代行を使う前に確認したい、非弁リスク、有給消化、会社からの連絡、退職届、料金比較の考え方をまとめています。";
const SITE_URL = import.meta.env.PUBLIC_TAISYOKU_SITE_URL ?? "https://taisyoku.hakobu-family.com";
const BASE_PATH = "/taisyoku";
const CANONICAL = `${SITE_URL}${BASE_PATH}/columns`;

const articles = [
  {
    title: "退職代行の非弁リスクとは？会社が対応を止めるケース",
    href: "/taisyoku/columns/hiben-risk",
    desc: "退職意思の伝達と、退職日・有給・未払いなどの交渉の違いを整理します。"
  },
  {
    title: "退職前に有給消化したいとき、先に確認すること",
    href: "/taisyoku/columns/paid-leave",
    desc: "退職日までに有給を使いたい場合の考え方と、揉めやすいポイントをまとめます。"
  },
  {
    title: "退職代行後に会社から連絡が来たらどう考える？",
    href: "/taisyoku/columns/company-contact",
    desc: "本人・家族への連絡、貸与品、書類対応などで慌てないための確認事項です。"
  },
  {
    title: "退職届・貸与品・書類はどう準備する？",
    href: "/taisyoku/columns/retirement-letter",
    desc: "退職代行を使う前に整理しておきたい、退職届や会社への返却物の基本です。"
  },
  {
    title: "安い退職代行を選ぶ前に見るべき対応範囲",
    href: "/taisyoku/columns/cost-vs-safety",
    desc: "料金だけで比較すると見落としやすい、弁護士・労組・民間型の違いを整理します。"
  }
];
---
<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{PAGE_TITLE}</title>
  <meta name="description" content={PAGE_DESC} />
  <meta name="robots" content="noindex, nofollow" />
  <link rel="canonical" href={CANONICAL} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700;900&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/taisyoku/styles.css" />
</head>
<body>
  <header class="site-header">
    <div class="container header-inner">
      <a class="brand" href="/taisyoku" aria-label={SITE_NAME}>
        <span class="brand-mark">h</span>
        <span><strong>{SITE_NAME}</strong><small>退職前の安全比較</small></span>
      </a>
      <nav class="nav" aria-label="関連ページ">
        <a href="/taisyoku">トップ</a>
        <a href="/taisyoku/operator">運営者情報</a>
      </nav>
    </div>
  </header>

  <main class="policy-page">
    <section class="policy-hero">
      <div class="container">
        <span class="section-kicker">COLUMNS</span>
        <h1>退職前コラム</h1>
        <p>退職代行を申し込む前に、短時間で確認したいポイントをまとめています。</p>
      </div>
    </section>

    <section class="section">
      <div class="container column-list">
        {articles.map((article) => (
          <article class="column-card">
            <h2><a href={article.href}>{article.title}</a></h2>
            <p>{article.desc}</p>
            <a href={article.href}>読む</a>
          </article>
        ))}
      </div>
    </section>
  </main>

  <footer class="site-footer">
    <div class="container footer-inner">
      <p>{SITE_NAME}</p>
      <nav>
        <a href="/taisyoku">トップ</a>
        <a href="/taisyoku/privacy">プライバシーポリシー</a>
        <a href="/taisyoku/disclosure">広告掲載について</a>
        <a href="/taisyoku/operator">運営者情報</a>
      </nav>
    </div>
  </footer>
</body>
</html>
